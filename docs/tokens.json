{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Design tokens for the Tic-Tac-Toe Game (surface: WEB). W3C DTCG format. Codified from the confirmed Claude Design system 'Tic-Tac-Toe Game UI'. Color roles are theme-independent names; the light values live under `color`, the dark-theme values under `colorDark`. Theme-independent scales (space, radius, type, elevation) are shared across both themes. See docs/design.md for usage rules.",

  "color": {
    "$description": "Light theme (default). Role-based semantic colors.",
    "bg":          { "$type": "color", "$value": "#F1EEE6", "$description": "App canvas — warm paper" },
    "surface":     { "$type": "color", "$value": "#FFFFFF", "$description": "Raised card/panel surface" },
    "surface2":    { "$type": "color", "$value": "#FBFAF6", "$description": "Recessed surface — the board tray" },
    "ink":         { "$type": "color", "$value": "#211C15", "$description": "Primary text; also the primary-button fill" },
    "muted":       { "$type": "color", "$value": "#8C8375", "$description": "Secondary/supporting text. NOTE: ~3.7:1 on white — use for large or non-essential text only; use mutedStrong for small essential text (see design.md)" },
    "mutedStrong": { "$type": "color", "$value": "#6E655A", "$description": "AA-compliant (~4.6:1 on white/paper) secondary text — added for accessibility; use for small essential labels" },
    "line":        { "$type": "color", "$value": "#E6E0D4", "$description": "Borders and hairline dividers" },

    "x":           { "$type": "color", "$value": "#2F6BD8", "$description": "Player X — blue" },
    "xSoft":       { "$type": "color", "$value": "#E7EEFB", "$description": "Player X tinted background" },
    "o":           { "$type": "color", "$value": "#E0663A", "$description": "Player O — orange; also the loss/danger role" },
    "oSoft":       { "$type": "color", "$value": "#FBEAE1", "$description": "Player O tinted background" },

    "primary":     { "$type": "color", "$value": "#211C15", "$description": "Primary action fill (= ink)" },
    "primaryInk":  { "$type": "color", "$value": "#FFFFFF", "$description": "Text/icon on primary fill" },

    "win":         { "$type": "color", "$value": "#2E9E5B", "$description": "Win/success — green" },
    "winSoft":     { "$type": "color", "$value": "#E4F4EA", "$description": "Win/success tinted background" },
    "winBorder":   { "$type": "color", "$value": "rgba(46,158,91,0.4)", "$description": "Winning-cell / result border" },

    "focus":       { "$type": "color", "$value": "#2F6BD8", "$description": "Focus-ring color (added for accessibility; = x)" }
  },

  "colorDark": {
    "$description": "Dark theme. Same roles as `color`, warm-dark derivation (FR-THEME-001).",
    "bg":          { "$type": "color", "$value": "#1A1712" },
    "surface":     { "$type": "color", "$value": "#241F18" },
    "surface2":    { "$type": "color", "$value": "#1F1B14" },
    "ink":         { "$type": "color", "$value": "#F1EDE4" },
    "muted":       { "$type": "color", "$value": "#A79E8E" },
    "mutedStrong": { "$type": "color", "$value": "#C3BBAB" },
    "line":        { "$type": "color", "$value": "#38322A" },

    "x":           { "$type": "color", "$value": "#6FA0EE" },
    "xSoft":       { "$type": "color", "$value": "#22314B" },
    "o":           { "$type": "color", "$value": "#F0885E" },
    "oSoft":       { "$type": "color", "$value": "#3A2419" },

    "primary":     { "$type": "color", "$value": "#F1EDE4" },
    "primaryInk":  { "$type": "color", "$value": "#1A1712" },

    "win":         { "$type": "color", "$value": "#4CC078" },
    "winSoft":     { "$type": "color", "$value": "#17301F" },
    "winBorder":   { "$type": "color", "$value": "rgba(76,192,120,0.45)" },

    "focus":       { "$type": "color", "$value": "#6FA0EE" }
  },

  "space": {
    "$description": "Spacing scale (px). Keys reflect the raw value for direct mapping.",
    "1":  { "$type": "dimension", "$value": "2px" },
    "2":  { "$type": "dimension", "$value": "4px" },
    "3":  { "$type": "dimension", "$value": "6px" },
    "4":  { "$type": "dimension", "$value": "8px" },
    "5":  { "$type": "dimension", "$value": "10px" },
    "6":  { "$type": "dimension", "$value": "12px" },
    "7":  { "$type": "dimension", "$value": "14px" },
    "8":  { "$type": "dimension", "$value": "16px" },
    "9":  { "$type": "dimension", "$value": "18px" },
    "10": { "$type": "dimension", "$value": "20px" },
    "12": { "$type": "dimension", "$value": "22px" },
    "16": { "$type": "dimension", "$value": "40px" },
    "20": { "$type": "dimension", "$value": "56px" }
  },

  "radius": {
    "xs":   { "$type": "dimension", "$value": "9px",  "$description": "Small glyph chips" },
    "sm":   { "$type": "dimension", "$value": "10px", "$description": "Inner segmented-control button" },
    "md":   { "$type": "dimension", "$value": "12px", "$description": "Badge tile" },
    "lg":   { "$type": "dimension", "$value": "14px", "$description": "Buttons, segmented control, pills" },
    "xl":   { "$type": "dimension", "$value": "16px", "$description": "Board cell" },
    "2xl":  { "$type": "dimension", "$value": "18px", "$description": "Cards, mode tiles, stat tiles, history panel" },
    "3xl":  { "$type": "dimension", "$value": "24px", "$description": "Board tray" },
    "pill": { "$type": "dimension", "$value": "999px", "$description": "Toggle, back button, result badges" }
  },

  "typography": {
    "family": {
      "rounded": { "$type": "fontFamily", "$value": ["SF Pro Rounded", "ui-rounded", "Hiragino Maru Gothic Pro", "Quicksand", "system-ui", "sans-serif"], "$description": "Single UI family — rounded humanist sans" }
    },
    "weight": {
      "medium":   { "$type": "fontWeight", "$value": 600, "$description": "Secondary/supporting text" },
      "bold":     { "$type": "fontWeight", "$value": 700, "$description": "Labels, buttons, body emphasis" },
      "heavy":    { "$type": "fontWeight", "$value": 800, "$description": "Headings, marks, numerals, strong emphasis" }
    },
    "size": {
      "2xs":       { "$type": "dimension", "$value": "11px", "$description": "Micro labels (stat-tile caption)" },
      "xs":        { "$type": "dimension", "$value": "12px", "$description": "Fine print, meta, uppercase labels" },
      "sm":        { "$type": "dimension", "$value": "13px", "$description": "Helper text, descriptions" },
      "base":      { "$type": "dimension", "$value": "14px", "$description": "History row title, footer link" },
      "md":        { "$type": "dimension", "$value": "15px", "$description": "Body, turn indicator, list/segment text" },
      "lg":        { "$type": "dimension", "$value": "16px", "$description": "Mode title, standard button" },
      "xl":        { "$type": "dimension", "$value": "17px", "$description": "Primary CTA (Start Game)" },
      "wordmark":  { "$type": "dimension", "$value": "20px", "$description": "Logo wordmark" },
      "displaySm": { "$type": "dimension", "$value": "24px", "$description": "Result banner headline" },
      "display":   { "$type": "dimension", "$value": "30px", "$description": "Screen title (h1); large numerals" },
      "mark":      { "$type": "dimension", "$value": "58px", "$description": "X / O mark inside a board cell" }
    },
    "tracking": {
      "tight":  { "$type": "dimension", "$value": "-0.01em", "$description": "Display headings" },
      "normal": { "$type": "dimension", "$value": "0em" },
      "wide":   { "$type": "dimension", "$value": "0.1em",  "$description": "Uppercase field labels" },
      "wider":  { "$type": "dimension", "$value": "0.14em", "$description": "Wordmark" }
    }
  },

  "elevation": {
    "card": { "$type": "shadow", "$value": [
      { "offsetX": "0px", "offsetY": "1px", "blur": "2px",  "spread": "0px", "color": "rgba(33,28,21,0.05)" },
      { "offsetX": "0px", "offsetY": "8px", "blur": "24px", "spread": "0px", "color": "rgba(33,28,21,0.06)" }
    ], "$description": "The single soft elevation used on all raised surfaces (light). Dark theme uses rgba(0,0,0,0.3)/(0,0,0,0.35)." }
  },

  "layout": {
    "appMaxWidth": { "$type": "dimension", "$value": "460px", "$description": "Centered single-column app width" },
    "stagePadding": { "$type": "dimension", "$value": "40px 20px 56px", "$description": "Viewport padding around the app column" },
    "appGap": { "$type": "dimension", "$value": "22px", "$description": "Vertical rhythm between major sections" },
    "touchTargetMin": { "$type": "dimension", "$value": "44px", "$description": "Minimum interactive target on touch (NFR-USE-002)" }
  }
}
